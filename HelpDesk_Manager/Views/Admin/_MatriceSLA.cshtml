@{
    Layout = null;
}
@{
    var slas = ViewData["SLAs"] as List<HelpDesk_Manager.Models.ConfigurationSLA>;
    var urgences = ViewData["Urgences"] as List<HelpDesk_Manager.Models.NiveauUrgence>;
    var impacts = ViewData["Impacts"] as List<HelpDesk_Manager.Models.NiveauImpact>;
    var titre = ViewData["Titre"] as string;
}

@* Matrice visuelle *@
<div class="card" style="margin-bottom:24px;">
    <div class="card-header"><h3>📊 @titre</h3></div>
    <div class="card-body" style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;text-align:center;">
            <thead>
                <tr>
                    <th style="padding:12px;background:#f8f9fa;border:1px solid #dee2e6;
                                min-width:120px;">
                        Urgence \ Impact
                    </th>
                    @foreach (var imp in impacts!)
                    {
                        <th style="padding:12px;background:#f8f9fa;border:1px solid #dee2e6;">
                            @imp.NomImpact
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var urg in urgences!)
                {
                    <tr>
                        <td style="padding:12px;font-weight:600;background:#f8f9fa;
                                   border:1px solid #dee2e6;">
                            @urg.NomUrgence
                        </td>
                        @foreach (var imp in impacts)
                        {
                            var sla = slas!.FirstOrDefault(s => s.IdUrgence == urg.IdUrgence
                            && s.IdImpact == imp.IdImpact);
                            var couleur = sla?.PrioriteResultante switch
                            {
                                "P1" => "#dc3545",
                                "P2" => "#fd7e14",
                                "P3" => "#ffc107",
                                "P4" => "#28a745",
                                _ => "#888"
                            };
                            <td style="padding:12px;border:1px solid #dee2e6;
                                       background:@(couleur + "22");">
                                @if (sla != null)
                                {
                                    <span style="background:@couleur;color:white;padding:2px 10px;
                                                 border-radius:20px;font-size:12px;font-weight:700;
                                                 display:block;margin-bottom:6px;">
                                        @sla.PrioriteResultante
                                    </span>
                                    <div style="font-size:11px;color:#555;">
                                        🕐 @sla.DelaiReponsHeures h
                                    </div>
                                    <div style="font-size:11px;color:#555;">
                                        ✅ @sla.DelaiResolutionHeures h
                                    </div>
                                }
                                else
                                {
                                    <span style="color:#ccc;">—</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Tableau modification *@
<div class="card">
    <div class="card-header"><h3>✏️ Modifier les délais</h3></div>
    <table class="table">
        <thead>
            <tr>
                <th>Urgence</th>
                <th>Impact</th>
                <th>Priorité</th>
                <th>Délai prise en charge (h)</th>
                <th>Délai résolution (h)</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sla in slas!.OrderBy(s => s.Urgence?.Ordre).ThenBy(s => s.Impact?.Ordre))
            {
                <tr>
                    <form method="post" asp-action="ModifierSLA" asp-controller="Admin">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="idSLA" value="@sla.IdSLA" />

                    <td style="font-weight:500;">@sla.Urgence?.NomUrgence</td>
                    <td style="font-weight:500;">@sla.Impact?.NomImpact</td>
                    <td>
                            @{
                                var c = sla.PrioriteResultante switch
                                {
                                    "P1" => "#dc3545",
                                    "P2" => "#fd7e14",
                                    "P3" => "#ffc107",
                                    _ => "#28a745"
                                };
                            }
                        <span style="background:@c;color:white;padding:2px 10px;
                                         border-radius:20px;font-size:11px;font-weight:700;">
                                @sla.PrioriteResultante
                        </span>
                    </td>
                    <td>
                        <input type="number" name="delaiReponsHeures"
                               value="@sla.DelaiReponsHeures" min="1" max="168"
                               style="width:80px;padding:6px;border:1.5px solid #ddd;
                                          border-radius:6px;font-size:13px;text-align:center;" />
                    </td>
                    <td>
                        <input type="number" name="delaiResolutionHeures"
                               value="@sla.DelaiResolutionHeures" min="1" max="720"
                               style="width:80px;padding:6px;border:1.5px solid #ddd;
                                          border-radius:6px;font-size:13px;text-align:center;" />
                    </td>
                    <td>
                        <button type="submit" class="btn btn-primary btn-sm">
                            💾 Sauvegarder
                        </button>
                    </td>
                    </form>
                </tr>
            }
        </tbody>
    </table>
</div>