@model List<HelpDesk_Manager.Models.ConfigurationSLA>
@{
    ViewData["Title"] = "Configuration SLA";
    var domaines = ViewBag.Domaines as List<HelpDesk_Manager.Models.Domaine>;
    var priorites = ViewBag.Priorites as List<string>;
}

<div class="page-header">
    <h1>⚙️ Configuration SLA</h1>
    <p>Délais de réponse et résolution par Priorité × Domaine</p>
</div>

@* Matrice visuelle *@
<div class="card" style="margin-bottom:24px;">
    <div class="card-header"><h3>📊 Matrice SLA</h3></div>
    <div class="card-body" style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;text-align:center;">
            <thead>
                <tr>
                    <th style="padding:12px;background:#f8f9fa;border:1px solid #dee2e6;min-width:80px;">
                        Priorité
                    </th>
                    @foreach (var dom in domaines!)
                    {
                        <th style="padding:12px;background:#f8f9fa;border:1px solid #dee2e6;">
                            @dom.NomDomaine
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var p in priorites!)
                {
                    var couleur = p switch
                    {
                        "P1" => "#dc3545",
                        "P2" => "#fd7e14",
                        "P3" => "#ffc107",
                        _ => "#28a745"
                    };
                    <tr>
                        <td style="padding:12px;border:1px solid #dee2e6;background:#f8f9fa;">
                            <span style="background:@couleur;color:white;padding:3px 12px;
                                         border-radius:20px;font-size:12px;font-weight:700;">
                                @p
                            </span>
                        </td>
                        @foreach (var dom in domaines!)
                        {
                            var sla = Model.FirstOrDefault(s => s.Priorite == p && s.IdDomaine == dom.IdDomaine);
                            <td style="padding:12px;border:1px solid #dee2e6;background:@(couleur + "18");">
                                @if (sla != null)
                                {
                                    <div style="font-size:11px;color:#555;">🕐 @sla.DelaiReponsHeures h</div>
                                    <div style="font-size:11px;color:#555;">✅ @sla.DelaiResolutionHeures h</div>
                                }
                                else
                                {
                                    <span style="color:#ccc;">—</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Tableau modification par onglet domaine *@
<div style="display:flex;gap:0;border-bottom:2px solid #e9ecef;margin-bottom:24px;overflow-x:auto;">
    @foreach (var dom in domaines!)
    {
        <button class="onglet @(dom == domaines.First() ? "active" : "")"
                onclick="afficherOnglet('dom_@dom.IdDomaine', this)">
            @dom.NomDomaine
        </button>
    }
</div>

@foreach (var dom in domaines!)
{
    <div id="onglet_dom_@dom.IdDomaine" class="contenu-onglet"
         style="display:@(dom == domaines.First() ? "block" : "none");">
        <div class="card">
            <div class="card-header"><h3>✏️ @dom.NomDomaine — Modifier les délais</h3></div>
            <table class="table">
                <thead>
                    <tr>
                        <th>Priorité</th>
                        <th>Délai prise en charge (h)</th>
                        <th>Délai résolution (h)</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in priorites!)
                    {
                        var sla = Model.FirstOrDefault(s => s.Priorite == p && s.IdDomaine == dom.IdDomaine);
                        var c = p switch
                        {
                            "P1" => "#dc3545",
                            "P2" => "#fd7e14",
                            "P3" => "#ffc107",
                            _ => "#28a745"
                        };
                        <tr>
                            <form method="post" asp-action="ModifierSLA" asp-controller="Admin">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="idSLA" value="@sla?.IdSLA" />
                            <td>
                                <span style="background:@c;color:white;padding:2px 10px;
                                                 border-radius:20px;font-size:11px;font-weight:700;">
                                        @p
                                </span>
                            </td>
                            <td>
                                <input type="number" name="delaiReponsHeures"
                                       value="@(sla?.DelaiReponsHeures ?? 0)" min="1" max="168"
                                       style="width:80px;padding:6px;border:1.5px solid #ddd;
                                                  border-radius:6px;font-size:13px;text-align:center;" />
                            </td>
                            <td>
                                <input type="number" name="delaiResolutionHeures"
                                       value="@(sla?.DelaiResolutionHeures ?? 0)" min="1" max="720"
                                       style="width:80px;padding:6px;border:1.5px solid #ddd;
                                                  border-radius:6px;font-size:13px;text-align:center;" />
                            </td>
                            <td>
                                <button type="submit" class="btn btn-primary btn-sm">💾 Sauvegarder</button>
                            </td>
                            </form>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<style>
    .onglet {
        padding: 10px 20px;
        border: none;
        background: none;
        font-size: 13px;
        font-weight: 500;
        color: #888;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        transition: 0.15s;
        white-space: nowrap;
    }

        .onglet:hover {
            color: #1a7a5e;
        }

        .onglet.active {
            color: #1a7a5e;
            border-bottom-color: #1a7a5e;
            font-weight: 700;
        }
</style>

<script>
    function afficherOnglet(id, btn) {
        document.querySelectorAll('.contenu-onglet').forEach(el => el.style.display = 'none');
        document.querySelectorAll('.onglet').forEach(el => el.classList.remove('active'));
        document.getElementById('onglet_' + id).style.display = 'block';
        btn.classList.add('active');
    }
</script>