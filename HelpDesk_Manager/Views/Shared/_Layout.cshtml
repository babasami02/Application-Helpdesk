@using System.Security.Claims
@using HelpDesk_Manager.Data
@inject AppDbContext _db

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — HelpDesk NOVEC</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f4f6f8;
            display: flex;
            min-height: 100vh;
        }

        /* ── SIDEBAR ─────────────────────────────── */
        .sidebar {
            width: 240px;
            background: #0d1f1a;
            color: white;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            overflow-y: auto;
        }

        .sidebar-brand {
            padding: 24px 20px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .sidebar-brand h2 {
            font-size: 20px;
            font-weight: 700;
            color: #2dce89;
            letter-spacing: 2px;
        }

        .sidebar-brand small {
            font-size: 10px;
            color: rgba(255,255,255,0.4);
            display: block;
            margin-top: 2px;
            letter-spacing: 1px;
        }

        .sidebar-badge {
            display: inline-block;
            background: #1a7a5e;
            color: #2dce89;
            font-size: 10px;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 10px;
            margin-top: 6px;
            letter-spacing: 1px;
        }

        .sidebar-nav {
            padding: 16px 0;
            flex: 1;
        }

        .nav-section {
            padding: 8px 16px 4px;
            font-size: 10px;
            font-weight: 700;
            color: rgba(255,255,255,0.3);
            letter-spacing: 1.5px;
            text-transform: uppercase;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 20px;
            color: rgba(255,255,255,0.65);
            text-decoration: none;
            font-size: 14px;
            transition: all 0.15s;
            border-left: 3px solid transparent;
        }

        .nav-link:hover, .nav-link.active {
            color: white;
            background: rgba(255,255,255,0.06);
            border-left-color: #2dce89;
        }

        .nav-link .icon {
            font-size: 16px;
            width: 20px;
            text-align: center;
        }

        /* ── TOPBAR ──────────────────────────────── */
        .main-wrapper {
            margin-left: 240px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .topbar {
            background: white;
            border-bottom: 1px solid #e9ecef;
            padding: 0 24px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .topbar-title {
            font-size: 18px;
            font-weight: 600;
            color: #2d3436;
        }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .btn-notif {
            position: relative;
            background: none;
            border: none;
            font-size: 20px;
            cursor: pointer;
            color: #666;
        }

        .notif-badge {
            position: absolute;
            top: -4px;
            right: -4px;
            background: #e74c3c;
            color: white;
            font-size: 10px;
            font-weight: 700;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            background: #1a7a5e;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
        }

        .user-menu {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: #444;
        }

        .btn-logout {
            background: none;
            border: 1px solid #ddd;
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 12px;
            cursor: pointer;
            color: #666;
            text-decoration: none;
        }

        .btn-logout:hover { background: #f8f9fa; color: #333; }

        /* ── CONTENU ─────────────────────────────── */
        .main-content {
            padding: 28px 28px;
            flex: 1;
        }

        /* ── COMPOSANTS COMMUNS ─────────────────── */
        .page-header {
            margin-bottom: 24px;
        }
        .page-header h1 {
            font-size: 22px;
            font-weight: 600;
            color: #2d3436;
        }
        .page-header p {
            font-size: 13px;
            color: #888;
            margin-top: 4px;
        }

        .card {
            background: white;
            border-radius: 10px;
            border: 1px solid #e9ecef;
            overflow: hidden;
        }

        .card-header {
            padding: 16px 20px;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .card-header h3 { font-size: 15px; font-weight: 600; color: #2d3436; }
        .card-body { padding: 20px; }

        /* Badges statut */
        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }
        .badge-nouveau          { background: #e3f9f5; color: #0d7a6e; }
        .badge-hors-perimetre   { background: #f3e8ff; color: #6f42c1; }
        .badge-en-cours         { background: #e3f2fd; color: #1565c0; }
        .badge-annule           { background: #ffebee; color: #c62828; }
        .badge-resolu           { background: #e8f5e9; color: #2e7d32; }
        .badge-ferme            { background: #f5f5f5; color: #616161; }

        /* Boutons */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            border-radius: 7px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            border: none;
            text-decoration: none;
            transition: 0.15s;
        }
        .btn-primary   { background: #1a7a5e; color: white; }
        .btn-primary:hover { background: #145f49; }
        .btn-danger    { background: #e74c3c; color: white; }
        .btn-secondary { background: #f1f3f5; color: #333; border: 1px solid #ddd; }
        .btn-secondary:hover { background: #e9ecef; }
        .btn-sm { padding: 5px 10px; font-size: 12px; }

        /* Table */
        .table { width: 100%; border-collapse: collapse; font-size: 14px; }
        .table th {
            background: #f8f9fa;
            padding: 10px 14px;
            text-align: left;
            font-size: 12px;
            font-weight: 600;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid #eee;
        }
        .table td {
            padding: 12px 14px;
            border-bottom: 1px solid #f0f0f0;
            color: #444;
            vertical-align: middle;
        }
        .table tr:last-child td { border-bottom: none; }
        .table tr:hover td { background: #fafbfc; }

        /* Alerts */
        .alert { padding: 12px 16px; border-radius: 8px; font-size: 13px; margin-bottom: 16px; }
        .alert-success { background: #e8f5e9; color: #2e7d32; border: 1px solid #a5d6a7; }
        .alert-danger  { background: #ffebee; color: #c62828; border: 1px solid #ef9a9a; }
        .alert-info    { background: #e3f2fd; color: #1565c0; border: 1px solid #90caf9; }
    </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
    <div class="sidebar-brand">
        <h2>NOVEC</h2>
        <small>GROUPE CDG</small>
        <span class="sidebar-badge">HELPDESK</span>
    </div>

    <nav class="sidebar-nav">
        @{
            var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
        }

        <div class="nav-section">Principal</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
           href="@Url.Action("Index","Home")">
            <span class="icon">🏠</span> Dashboard
        </a>

        @if (role == "Employe")
        {
            <div class="nav-section">Mes demandes</div>
            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Creer" ? "active" : "")"
               href="@Url.Action("Creer","Tickets")">
                <span class="icon">✏️</span> Nouveau ticket
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tickets" && ViewContext.RouteData.Values["action"]?.ToString() != "Creer" ? "active" : "")"
               href="@Url.Action("Index","Tickets")">
                <span class="icon">🎫</span> Mes tickets
            </a>
        }

        @if (role == "Helpdesk" || role == "Administrateur")
        {
            <div class="nav-section">Helpdesk</div>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Helpdesk" ? "active" : "")"
               href="@Url.Action("Index","Helpdesk")">
                <span class="icon">📋</span> Consultation tickets
            </a>
            <a class="nav-link" href="@Url.Action("Performance","Helpdesk")">
                <span class="icon">📊</span> Performance
            </a>
        }

        @if (role == "Technicien" || role =="Helpdesk")
        {
            <div class="nav-section">Interventions</div>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Technicien" ? "active" : "")"
               href="@Url.Action("MesTickets","Technicien")">
                <span class="icon">🔧</span> Mes Interventions
            </a>
        }

        @if (role == "Administrateur")
        {
            <div class="nav-section">Administration</div>
            <a class="nav-link" href="@Url.Action("Index","Admin")">
                <span class="icon">⚙️</span> Gestion utilisateurs
            </a>
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "SLA" ? "active" : "")"
                   href="@Url.Action("SLA","Admin")">
                    <span class="icon">⏱️</span> Configuration SLA
                </a>
        }
    </nav>
</aside>

<!-- MAIN -->
<div class="main-wrapper">
    <!-- TOPBAR -->
    <header class="topbar">
        <span class="topbar-title">@ViewData["Title"]</span>
        <div class="topbar-actions">
                @{
                    var idUserStr = User.FindFirst("IdUtilisateur")?.Value;

                    var nbNotifs = 0;

                    if (idUserStr != null)

                    {
                        var idU = int.Parse(idUserStr);
                        nbNotifs = _db.Notifications.Count(n => n.IdUtilisateur == idU && !n.IsLue);

                    }
                }
                <button class="btn-notif" title="Notifications"
                        onclick="window.location='@Url.Action("Index","Notifications")'">
                    🔔
                    @if (nbNotifs > 0)

                    {
                        <span class="notif-badge">@(nbNotifs > 9 ? "9+" : nbNotifs.ToString())</span>
                    }
                </button>
                <div class="user-menu">
                <div class="user-avatar">
                    @{
                        var nomComplet = User.FindFirst("NomComplet")?.Value ?? "?";
                        var initiales = string.Concat(nomComplet.Split(' ').Take(2).Select(s => s.Length > 0 ? s[0].ToString().ToUpper() : ""));
                    }
                    @initiales
                </div>
                <div>
                    <div style="font-weight:600;font-size:13px;">@nomComplet</div>
                    <div style="font-size:11px;color:#999;">@role</div>
                </div>
                <a href="@Url.Action("Logout","Account")" class="btn-logout">Déconnexion</a>
            </div>
        </div>
    </header>

    <!-- CONTENU DE LA PAGE -->
    <main class="main-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">✅ @TempData["Success"]</div>
        }
        @if (TempData["Erreur"] != null)
        {
            <div class="alert alert-danger">❌ @TempData["Erreur"]</div>
        }

        @RenderBody()
    </main>
</div>

</body>
</html>
