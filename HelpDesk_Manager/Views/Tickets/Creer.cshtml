@model HelpDesk_Manager.Models.Ticket
@{
    ViewData["Title"] = "Nouveau Ticket";
}

<div class="page-header">
    <h1>Créer un ticket</h1>
    <p>Décrivez votre problème ou demande en détail</p>
</div>

<div style="max-width:700px;">
    <div class="card">
        <div class="card-header">
            <h3>📝 Informations du ticket</h3>
        </div>
        <div class="card-body">
            <form method="post" asp-action="Creer" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                @* Ligne Ticket No + Date *@
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
                    <div>
                        <label class="form-label">Ticket N°</label>
                        <input type="text" class="form-input" value="Auto-généré" disabled />
                    </div>
                    <div>
                        <label class="form-label">Date</label>
                        <input type="text" class="form-input" value="@DateTime.Now.ToString("dd/MM/yyyy")" disabled />
                    </div>
                </div>

                @* Sujet *@
                <div style="margin-bottom:16px;">
                    <label class="form-label">
                        Sujet <span style="color:#e74c3c;">*</span>
                    </label>
                    <input asp-for="Titre" class="form-input"
                           placeholder="Résumé court du problème" required />
                    <span asp-validation-for="Titre" style="color:#e74c3c;font-size:12px;"></span>
                </div>

                @* Domaine et Nature renseignés par le Helpdesk lors de la qualification *@

                @* Description *@
                <div style="margin-bottom:16px;">
                    <label class="form-label">
                        Description <span style="color:#e74c3c;">*</span>
                    </label>
                    <textarea asp-for="Description" class="form-input"
                              rows="5"
                              placeholder="Décrivez le problème en détail : quand est-il apparu, quel est l'impact sur votre travail..."
                              required></textarea>
                    <span asp-validation-for="Description" style="color:#e74c3c;font-size:12px;"></span>
                </div>

                @* Pièce jointe *@
                <div style="margin-bottom:24px;">
                    <label class="form-label">Pièce jointe (capture d'écran, document...)</label>
                    <div style="border:2px dashed #ddd;border-radius:8px;padding:20px;text-align:center;cursor:pointer;"
                         onclick="document.getElementById('fichier').click()">
                        <div style="font-size:24px;margin-bottom:8px;">📎</div>
                        <div style="font-size:13px;color:#888;">
                            Cliquez pour joindre un fichier
                            <br /><small>JPG, PNG, PDF — max 5 Mo</small>
                        </div>
                        <input type="file" id="fichier" name="fichier"
                               accept=".jpg,.jpeg,.png,.pdf,.doc,.docx"
                               style="display:none"
                               onchange="afficherNomFichier(this)" />
                    </div>
                    <div id="nom-fichier" style="font-size:12px;color:#1a7a5e;margin-top:6px;"></div>
                </div>

                @* Boutons *@
                <div style="display:flex;gap:12px;justify-content:flex-end;">
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        Annuler
                    </a>
                    <button type="submit" class="btn btn-primary">
                        ✅ Soumettre le ticket
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Styles formulaire *@
<style>
    .form-label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #444;
        margin-bottom: 6px;
    }
    .form-input {
        width: 100%;
        padding: 10px 12px;
        border: 1.5px solid #ddd;
        border-radius: 8px;
        font-size: 14px;
        font-family: inherit;
        outline: none;
        transition: border-color 0.2s;
        background: white;
    }
    .form-input:focus {
        border-color: #1a7a5e;
        box-shadow: 0 0 0 3px rgba(26,122,94,0.1);
    }
    .form-input:disabled {
        background: #f8f9fa;
        color: #999;
    }
    textarea.form-input { resize: vertical; }
</style>

<script>
    function afficherNomFichier(input) {
        if (input.files.length > 0) {
            document.getElementById('nom-fichier').textContent = '✅ ' + input.files[0].name;
        }
    }
</script>