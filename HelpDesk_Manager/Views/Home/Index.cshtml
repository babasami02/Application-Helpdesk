@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <h1>Bienvenue sur le HelpDesk NOVEC</h1>
    <p>Vue d'ensemble de l'activité en temps réel</p>
</div>

<!-- KPI Cards -->
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px;">
    <div class="card" style="padding:20px;">
        <div style="font-size:12px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Total tickets</div>
        <div style="font-size:36px;font-weight:700;color:#2d3436;margin:8px 0;">@ViewBag.TotalTickets</div>
        <div style="font-size:12px;color:#2dce89;">↑ Tous statuts confondus</div>
    </div>
    <div class="card" style="padding:20px;">
        <div style="font-size:12px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Nouveaux</div>
        <div style="font-size:36px;font-weight:700;color:#17a2b8;margin:8px 0;">@ViewBag.NouveauxTickets</div>
        <div style="font-size:12px;color:#888;">En attente de qualification</div>
    </div>
    <div class="card" style="padding:20px;">
        <div style="font-size:12px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">En cours</div>
        <div style="font-size:36px;font-weight:700;color:#007bff;margin:8px 0;">@ViewBag.EnCours</div>
        <div style="font-size:12px;color:#888;">En traitement actif</div>
    </div>
    <div class="card" style="padding:20px;">
        <div style="font-size:12px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Résolus</div>
        <div style="font-size:36px;font-weight:700;color:#28a745;margin:8px 0;">@ViewBag.Resolus</div>
        <div style="font-size:12px;color:#28a745;">✓ Clôturés avec succès</div>
    </div>
</div>

<!-- Actions rapides -->
<!-- Actions rapides -->
<div class="card" style="margin-bottom:20px;">
    
    <!-- Nouveaux tickets -->
    <div class="card">
        <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
            <h3>📩 Nouveaux tickets en attente</h3>
            <a href="@Url.Action("Index","Helpdesk")" style="font-size:13px;color:#1a7a5e;">Voir tout →</a>
        </div>
        <table class="table">
            <thead>
                <tr>
                    <th>N°</th>
                    <th>Sujet</th>
                    <th>Domaine</th>
                    <th>Demandeur</th>
                    <th>Date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @{
                    var nouveaux = ViewBag.NouveauxTicketsList as List<HelpDesk_Manager.Models.Ticket>;
                }
                @if (nouveaux == null || !nouveaux.Any())

                {
                    <tr>
                        <td colspan="6" style="text-align:center;padding:30px;color:#999;">
                            Aucun nouveau ticket en attente. 🎉
                        </td>
                    </tr>
                }
                @foreach (var t in nouveaux ?? new())

                {
                    <tr>
                        <td>
                            <a href="@Url.Action("Details","Helpdesk", new { id = t.IdTicket })"
                               style="color:#1a7a5e;font-weight:700;">
                                @t.NumeroAnnuel/@t.DateOuverture.Year
                            </a>
                        </td>
                        <td style="font-weight:500;max-width:200px;">@t.Titre</td>
                        <td style="font-size:12px;color:#888;">@(t.Domaine?.NomDomaine ?? "—")</td>
                        <td style="font-size:12px;color:#888;">@(t.Demandeur?.NomComplet ?? "—")</td>
                        <td style="font-size:12px;color:#888;">@t.DateOuverture.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <a href="@Url.Action("Details","Helpdesk", new { id = t.IdTicket })"
                               class="btn btn-secondary btn-sm">Qualifier</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

