@{
    ViewData["Title"] = "Mon Dashboard";
}

<div class="page-header" style="display:flex;justify-content:space-between;align-items:center;">
    <div>
        <h1>Bonjour, @User.FindFirst("NomComplet")?.Value </h1>
        <p>Voici un résumé de vos demandes</p>
    </div>
    <a href="@Url.Action("Creer","Tickets")" class="btn btn-primary">
        ✏️ Nouveau ticket
    </a>
</div>

@* Alerte tickets à noter *@
@if (ViewBag.ANoter > 0)
{
    <div style="background:#fff8e1;border:1px solid #ffc107;border-radius:10px;
                padding:14px 20px;margin-bottom:24px;display:flex;
                align-items:center;justify-content:space-between;">
        <div>
            <span style="font-weight:600;color:#f57f17;">⭐ @ViewBag.ANoter ticket(s) en attente de votre évaluation</span>
            <span style="font-size:13px;color:#888;margin-left:8px;">
                Notez la prestation pour clôturer définitivement
            </span>
        </div>
        <a href="@Url.Action("Index","Tickets")" class="btn btn-sm"
           style="background:#ffc107;color:#333;font-weight:600;">
            Voir →
        </a>
    </div>
}

@* KPI Cards *@
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px;">
    <div class="card" style="padding:20px;text-align:center;">
        <div style="font-size:11px;color:#888;font-weight:600;
                    text-transform:uppercase;letter-spacing:0.5px;">
            Total
        </div>
        <div style="font-size:40px;font-weight:700;color:#2d3436;margin:8px 0;">
            @ViewBag.Total
        </div>
        <div style="font-size:12px;color:#888;">Mes tickets</div>
    </div>
    <div class="card" style="padding:20px;text-align:center;">
        <div style="font-size:11px;color:#888;font-weight:600;
                    text-transform:uppercase;letter-spacing:0.5px;">
            En cours
        </div>
        <div style="font-size:40px;font-weight:700;color:#007bff;margin:8px 0;">
            @ViewBag.EnCours
        </div>
        <div style="font-size:12px;color:#888;">En traitement</div>
    </div>
    <div class="card" style="padding:20px;text-align:center;">
        <div style="font-size:11px;color:#888;font-weight:600;
                    text-transform:uppercase;letter-spacing:0.5px;">
            Résolus
        </div>
        <div style="font-size:40px;font-weight:700;color:#28a745;margin:8px 0;">
            @ViewBag.Resolus
        </div>
        <div style="font-size:12px;color:#28a745;">✓ Clôturés</div>
    </div>
    <div class="card" style="padding:20px;text-align:center;">
        <div style="font-size:11px;color:#888;font-weight:600;
                    text-transform:uppercase;letter-spacing:0.5px;">
            Annulés
        </div>
        <div style="font-size:40px;font-weight:700;color:#e74c3c;margin:8px 0;">
            @ViewBag.Rejetes
        </div>
        <div style="font-size:12px;color:#888;">Hors périmètre / Annulés</div>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr ;gap:20px;">

    @* Tickets récents *@
    <div class="card">
        <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
            <h3>🕐 Mes tickets récents</h3>
            <a href="@Url.Action("Index","Tickets")"
               style="font-size:13px;color:#1a7a5e;">Voir tout →</a>
        </div>
        <table class="table">
            <thead>
                <tr>
                    <th>N°</th>
                    <th>Sujet</th>
                    <th>Domaine</th>
                    <th>Statut</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @if (!(ViewBag.Recents as List<HelpDesk_Manager.Models.Ticket>)!.Any())
                {
                    <tr>
                        <td colspan="5" style="text-align:center;padding:30px;color:#999;">
                            Aucun ticket pour le moment.
                            <a href="@Url.Action("Creer","Tickets")">Créer votre premier ticket →</a>
                        </td>
                    </tr>
                }
                @foreach (var t in ViewBag.Recents as List<HelpDesk_Manager.Models.Ticket>)
                {
                    <tr>
                        <td>
                            <a href="@Url.Action("Details","Tickets", new { id = t.IdTicket })"
                               style="color:#1a7a5e;font-weight:700;">@t.NumeroAnnuel/@t.DateOuverture.Year</a>
                        </td>
                        <td style="font-weight:500;max-width:180px;">@t.Titre</td>
                        <td style="font-size:12px;color:#888;">
                            @(t.Domaine?.NomDomaine ?? "—")
                        </td>
                        <td>
                            @{
                                var css = t.Statut?.NomStatut switch
                                {
                                    "Nouveau" => "badge-nouveau",
                                    "Hors périmètre" => "badge-hors-perimetre",
                                    "En cours" => "badge-en-cours",
                                    "Annulé" => "badge-annule",
                                    "Résolu" => "badge-resolu",
                                    "Fermé" => "badge-ferme",
                                    _ => ""
                                };
                            }
                            <span class="badge @css">@t.Statut?.NomStatut</span>
                        </td>
                        <td style="font-size:12px;color:#888;">
                            @t.DateOuverture.ToString("dd/MM/yyyy")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

